{
  "name": "@pungfe/element",
  "type": "module",
  "version": "0.0.1-alpha.26",
  "description": "Element Plus Components",
  "author": "pungfeng <fp94214@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/pungfen/element",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungfen/element.git"
  },
  "bugs": {
    "url": "https://github.com/pungfen/element/issues"
  },
  "keywords": [
    "Element Plus",
    "typescript",
    "vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./advance": {
      "types": "./dist/types/advance.d.ts",
      "import": "./dist/es/advance.js",
      "require": "./dist/cjs/advance.js"
    },
    "./resolver": {
      "types": "./dist/types/resolver.d.ts",
      "import": "./dist/es/resolver.js",
      "require": "./dist/cjs/resolver.js"
    },
    "./style.css": {
      "import": "./dist/es/element.css",
      "require": "./dist/cjs/element.css"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "eslint . --cache --concurrency=auto",
    "prepare": "simple-git-hooks",
    "typecheck": "vue-tsc --noEmit",
    "release": "npm run build && bumpp",
    "test": "vitest",
    "test:ci": "vitest run"
  },
  "peerDependencies": {
    "element-plus": "^2.13.1",
    "vue": "^3.5.27"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "element-plus": "^2.13.1",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "bumpp": "^11.0.1",
    "eslint": "^10.1.0",
    "fast-glob": "^3.3.3",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "vue-component-type-helpers": "^3.2.6",
    "vue-tsc": "^3.2.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,vue,tsx,jsx}": "eslint --fix"
  }
}
