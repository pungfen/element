{
  "name": "@pungfe/element",
  "type": "module",
  "version": "0.0.1-alpha.21",
  "description": "Element Plus Components",
  "author": "pungfeng <fp94214@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/pungfen/element",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungfen/element.git"
  },
  "bugs": {
    "url": "https://github.com/pungfen/element/issues"
  },
  "keywords": [
    "Element Plus",
    "typescript",
    "vue"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./resolver": {
      "types": "./dist/types/resolver.d.ts",
      "import": "./dist/es/resolver.js",
      "require": "./dist/cjs/resolver.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.js",
  "types": "./dist/types/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "scripts": {
    "build": "vite build",
    "lint": "eslint .",
    "prepare": "simple-git-hooks",
    "typecheck": "vue-tsc --noEmit",
    "release": "npm run build && bumpp",
    "test": "vitest"
  },
  "peerDependencies": {
    "element-plus": "^2.13.1",
    "vue": "^3.5.27"
  },
  "dependencies": {
    "@vueuse/core": "^14.2.1",
    "element-plus": "^2.13.1",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "bumpp": "^11.0.1",
    "eslint": "^10.0.3",
    "fast-glob": "^3.3.3",
    "jiti": "^2.6.1",
    "jsdom": "^29.0.0",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  },
  "publishConfig": {
    "access": "public"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
