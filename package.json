{
  "name": "@pungfe/element",
  "version": "0.0.1-alpha.29",
  "description": "Element Plus Components",
  "keywords": [
    "Element Plus",
    "typescript",
    "vue"
  ],
  "homepage": "https://github.com/pungfen/element",
  "bugs": {
    "url": "https://github.com/pungfen/element/issues"
  },
  "license": "MIT",
  "author": "pungfeng <fp94214@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungfen/element.git"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./advance": {
      "types": "./dist/advance.d.ts",
      "import": "./dist/advance.js",
      "require": "./dist/advance.js"
    },
    "./basic": {
      "types": "./dist/basic.d.ts",
      "import": "./dist/basic.js",
      "require": "./dist/basic.js"
    },
    "./locales": {
      "types": "./dist/locales.d.ts",
      "import": "./dist/locales.js",
      "require": "./dist/locales.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js",
      "require": "./dist/resolver.js"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "fmt": "oxfmt",
    "lint": "oxlint -c oxlint.config.ts --type-aware",
    "lint:fix": "oxlint --fix",
    "prepare": "simple-git-hooks",
    "release": "npm run build && bumpp",
    "test": "vitest",
    "test:ci": "vitest run",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.2.1",
    "@vueuse/integrations": "^14.2.1",
    "element-plus": "^2.13.1",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.27"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/sortablejs": "^1.15.9",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/language-core": "^3.2.6",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "bumpp": "^11.0.1",
    "eslint-plugin-perfectionist": "^5.7.0",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.58.0",
    "oxlint-tsgolint": "^0.19.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "unplugin-raw": "^0.7.0",
    "unplugin-vue": "^7.1.1",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^8.0.3",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.2",
    "vue-component-type-helpers": "^3.2.6",
    "vue-tsc": "^3.2.6"
  },
  "peerDependencies": {
    "element-plus": "^2.13.1",
    "vue": "^3.5.27"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,vue,tsx,jsx}": "oxlint --fix"
  }
}
