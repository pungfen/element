{
  "name": "@pungfe/element",
  "version": "0.5.4",
  "description": "Element Plus Components",
  "keywords": [
    "Element Plus",
    "typescript",
    "vue"
  ],
  "homepage": "https://github.com/pungfen/element",
  "bugs": {
    "url": "https://github.com/pungfen/element/issues"
  },
  "license": "MIT",
  "author": "pungfeng <fp94214@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pungfen/element.git"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./advance": {
      "types": "./dist/advance.d.ts",
      "import": "./dist/advance.js",
      "require": "./dist/advance.js"
    },
    "./basic": {
      "types": "./dist/basic.d.ts",
      "import": "./dist/basic.js",
      "require": "./dist/basic.js"
    },
    "./locales": {
      "types": "./dist/locales.d.ts",
      "import": "./dist/locales.js",
      "require": "./dist/locales.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js",
      "require": "./dist/resolver.js"
    },
    "./style.css": {
      "import": "./dist/style.css",
      "require": "./dist/style.css"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "build:dev": "vite build --mode staging",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "prepare": "simple-git-hooks",
    "release": "npm run build && bumpp",
    "test": "vitest",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@vueuse/core": "^14.3.0",
    "@vueuse/integrations": "^14.3.0",
    "element-plus": "~2.14.0",
    "sortablejs": "^1.15.7",
    "vue": "~3.5.35"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/language-core": "^3.3.2",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.1",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "unplugin-raw": "^0.7.0",
    "unplugin-vue": "^7.2.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^8.0.14",
    "vite-plugin-dts": "^5.0.1",
    "vitest": "^4.1.7",
    "vue-component-type-helpers": "^3.3.2",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.3.2"
  },
  "peerDependencies": {
    "element-plus": "~2.14.0",
    "vue": "~3.5.35"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,vue,tsx,jsx}": "oxlint --fix"
  }
}
